@using FcmsPortal.Models
@using FcmsPortal.Enums
@using FcmsPortal.Constants
@using FcmsPortal

<div class="modal fade @(IsVisible ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center">
                    <i class="fa fa-user-graduate text-primary me-2"></i>
                    @ArchivedStudent?.StudentName – Grade Report (Archived)
                </h5>
                <button type="button" class="btn-close" @onclick="Close"></button>
            </div>

            <div class="modal-body">
                @if (ArchivedStudent != null)
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fa fa-info-circle"></i> Student Overview</h6>
                        </div>

                        <div class="card-body">
                            <div class="row">

                                <div class="col-md-6">
                                    <p><strong>Student Name:</strong> @ArchivedStudent.StudentName</p>
                                    <p><strong>Learning Path:</strong> @ArchivedStudent.ArchivedLearningPathGrade?.LearningPathName</p>
                                    <p><strong>Term:</strong> @ArchivedStudent.ArchivedLearningPathGrade?.Semester.ToTermDisplay()</p>
                                </div>

                                <div class="col-md-6 text-center">
                                    <h4 class="text-primary">Term Overall Grade</h4>
                                    <h2 class="text-success">@ArchivedStudent.SemesterOverallGrade.ToString("F2")%</h2>

                                    <div class="mt-2">
                                        <span class="fs-4 fw-bold @Util.GetRankColorClass(ArchivedStudent.StudentRank)">
                                            @Util.GetOrdinalNumber(ArchivedStudent.StudentRank)
                                        </span>
                                        <div class="text-muted small">
                                            out of @ArchivedStudent.ArchivedLearningPathGrade?.TotalStudentsInPath students
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fa fa-books"></i> Course Breakdown</h6>
                        </div>

                        <div class="card-body">
                            @foreach (var course in ArchivedStudent.CourseGrades)
                            {
                                <div class="card mb-3 shadow-sm">
                                    <div class="card-header bg-light">
                                        <div class="row align-items-center">
                                            <div class="col">
                                                <h6 class="mb-0">@course.Course</h6>
                                            </div>
                                            <div class="col-auto">
                                                <span class="badge bg-@Util.GetGradeColorClass(course.TotalGrade) fs-6">
                                                    @course.TotalGrade.ToString("F1")%
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card-body">

                                        <div class="row text-center">

                                            <div class="col-md-4">
                                                <div class="card">
                                                    <div class="card-body">
                                                        <h6 class="text-muted">Homework</h6>
                                                        <h4 class="text-primary">
                                                            @course.HomeworkAverage.ToString("F1")
                                                        </h4>
                                                        <small class="text-muted">@course.TestGrades.Count(t => t.GradeType == GradeType.Homework) assignments</small>
                                                        <br />
                                                        <small class="text-success"><strong>Achieved:</strong> @((course.HomeworkAverage * course.HomeworkWeightPercentage / 100).ToString("F1"))%</small>
                                                        <br />
                                                        <small class="text-muted">Weight: @course.HomeworkWeightPercentage%</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="card">
                                                    <div class="card-body">
                                                        <h6 class="text-muted">Quiz</h6>
                                                        <h4 class="text-warning">
                                                            @course.QuizAverage.ToString("F1")
                                                        </h4>
                                                        <small class="text-muted">@course.TestGrades.Count(t => t.GradeType == GradeType.Quiz) quizzes</small>
                                                        <br />
                                                        <small class="text-success"><strong>Achieved:</strong> @((course.QuizAverage * course.QuizWeightPercentage / 100).ToString("F1"))%</small>
                                                        <br />
                                                        <small class="text-muted">Weight: @course.QuizWeightPercentage%</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="card">
                                                    <div class="card-body">
                                                        <h6 class="text-muted">Exam</h6>
                                                        <h4 class="text-danger">
                                                            @course.ExamAverage.ToString("F1")
                                                        </h4>
                                                        <small class="text-muted">@course.TestGrades.Count(t => t.GradeType == GradeType.Exam) exams</small>
                                                        <br />
                                                        <small class="text-success"><strong>Achieved:</strong> @((course.ExamAverage * course.FinalExamWeightPercentage / 100).ToString("F1"))%</small>
                                                        <br />
                                                        <small class="text-muted">Weight: @course.FinalExamWeightPercentage%</small>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="mt-3">
                                            <h6>Grade Details</h6>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-striped">
                                                    <thead>
                                                        <tr>
                                                            <th>Date</th>
                                                            <th>Type</th>
                                                            <th>Score</th>
                                                            <th>Teacher</th>
                                                            <th>Remarks</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var grade in course.TestGrades.OrderByDescending(g => g.Date))
                                                        {
                                                            <tr>
                                                                <td>@grade.Date.ToString("MMM dd, yyyy")</td>
                                                                <td>
                                                                    <span class="badge bg-secondary">
                                                                        @Util.GetGradeTypeName(grade.GradeType)
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <span class="fw-bold @Util.GetGradeColorClass(grade.Score, useTextPrefix: true)">
                                                                        @grade.Score.ToString("F1")%
                                                                    </span>
                                                                </td>
                                                                <td>@grade.TeacherName</td>
                                                                <td>@grade.TeacherRemark</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Summary Statistics -->
                    <div class="card mt-4">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fa fa-chart-bar"></i> Performance Summary</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <h6 class="text-muted">Total Courses</h6>
                                        <h4>@ArchivedStudent.CourseGrades.Count</h4>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <h6 class="text-muted">Position in Class</h6>
                                        <h4>@(ArchivedStudent.StudentRank > 0 ? Util.GetOrdinalNumber(ArchivedStudent.StudentRank) : "N/A")</h4>
                                        <h6 class="text-muted">out of @ArchivedStudent.ArchivedLearningPathGrade?.TotalStudentsInPath</h6>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        @{
                                            var highest = ArchivedStudent.CourseGrades.OrderByDescending(c => c.TotalGrade).FirstOrDefault();
                                        }
                                        <h6 class="text-muted">Highest Course</h6>
                                        <h4 class="text-success">@(highest?.TotalGrade.ToString("F1") ?? "0.0")%</h4>
                                        <small class="text-muted">@(highest?.Course ?? "N/A")</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        @{
                                            var lowest = ArchivedStudent.CourseGrades.Where(c => c.TotalGrade > 0).OrderBy(c => c.TotalGrade).FirstOrDefault();
                                        }
                                        <h6 class="text-muted">Lowest Course</h6>
                                        <h4 class="text-danger">@(lowest?.TotalGrade.ToString("F1") ?? "0.0")%</h4>
                                        <small class="text-muted">@(lowest?.Course ?? "N/A")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="Close">Close</button>
            </div>

        </div>
    </div>
</div>

@if (IsVisible)
{
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ArchivedStudentGrade? ArchivedStudent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private void Close() => OnClose.InvokeAsync();
}
